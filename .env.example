# Stock Buddy — local development (Docker Compose)
DATABASE_URL=postgresql://stockbuddy:stockbuddy@localhost:5432/stockbuddy

# Data MCP (optional HTTP mode)
STOCK_BUDDY_DATA_HTTP=0
STOCK_BUDDY_DATA_PORT=8081

# Enable admin ingest tools on data MCP
STOCK_BUDDY_DATA_ADMIN=1

# Web dashboard (market data explorer)
STOCK_BUDDY_DASHBOARD_PORT=3000

# DSE TLS: dsebd.org uses an incomplete certificate chain (handled automatically in scraper)

# Analysis MCP (existing)
STOCK_BUDDY_HTTP=0
STOCK_BUDDY_SKILLS_DIR=./skills
# Persist analyze_ticker results to analysis_snapshots when DATABASE_URL is set
STOCK_BUDDY_PERSIST_ANALYSIS=1
