{
  "name": "@stock-buddy/ingest",
  "version": "2.0.0",
  "description": "DSE data ingestion jobs and contract builder for Stock Buddy",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
