    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stock-buddy/core": "file:../core",
    "@stock-buddy/db": "file:../db",
    "@stock-buddy/mcp-server": "file:../mcp-server",
    "@stock-buddy/scraper": "file:../scraper"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
