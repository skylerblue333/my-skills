{
  "name": "@stock-buddy/dashboard",
  "version": "2.0.0",
  "description": "Web dashboard for Stock Buddy PostgreSQL market data",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "predev": "sh -c 'lsof -ti :${STOCK_BUDDY_DASHBOARD_PORT:-3000} | xargs kill 2>/dev/null || true'",
    "dev": "tsx src/server.ts"
  },
  "dependencies": {
    "@stock-buddy/db": "file:../db",
    "@stock-buddy/ingest": "file:../ingest",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
