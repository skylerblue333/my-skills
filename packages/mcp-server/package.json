{
  "name": "@stock-buddy/mcp-server",
  "version": "2.0.0",
  "description": "Stock Buddy MCP server — exposes DSE analysis skills as MCP tools",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./composites": {
      "types": "./dist/composites.d.ts",
      "import": "./dist/composites.js"
    }
  },
  "bin": {
    "stock-buddy-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stock-buddy/core": "file:../core",
    "@stock-buddy/db": "file:../db",
    "@stock-buddy/skills": "file:../skills",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
