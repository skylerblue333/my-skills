  "dataArchitecture": {
    "dataStores": [
      {
        "name": "Skill Fixtures",
        "technology": "JSON files",
        "purpose": "Test data for validation",
        "dataTypes": ["OHLCV", "fundamentals", "market data"]
      },
      {
        "name": "Adapter Cache",
        "technology": "File/Redis cache",
        "purpose": "Reduce API calls",
        "dataTypes": ["Ticker data", "Market snapshots"],
        "accessPatterns": ["Read-through cache", "TTL expiry"]
      }
    ],
    "coreEntities": [
      {
        "name": "TickerData",
        "description": "Normalized market data for a stock",
        "fields": [
          {"name": "ticker", "type": "string", "required": true},
          {"name": "ohlcv", "type": "array", "required": false},
          {"name": "fundamentals", "type": "object", "required": false},
          {"name": "news", "type": "array", "required": false}
        ],
        "relationships": ["Input to all skills"]
      },
      {
        "name": "ThinkingCard",
        "description": "Standardized skill output",
        "fields": [
          {"name": "score", "type": "number", "required": true},
          {"name": "rating", "type": "string", "required": true},
          {"name": "confidence", "type": "number", "required": true},
          {"name": "reasoning", "type": "array", "required": true},
          {"name": "recommendations", "type": "object", "required": false}
        ],
        "relationships": ["Output from all skills"]
      }
    ],
    "dataFlowDescription": "Data flows from external sources through the adapter (with caching), gets normalized into TickerData, passes to skills for analysis, produces ThinkingCards, which are aggregated by composite tools and returned to clients.",
    "cachingStrategy": "Multi-level caching: adapter cache for external data (5-15 min TTL), result cache for computed analysis (1 min), with cache invalidation on market events.",
    "dataRetention": "Cache-only retention for market data (no permanent storage), analysis results logged for performance tracking (30 day retention)."
  },
