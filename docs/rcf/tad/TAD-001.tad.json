  "architecturalDecisions": [
    {
      "id": "ADR-001",
      "title": "Python for all components",
      "status": "accepted",
      "context": "Need to choose implementation language for skills and server",
      "optionsConsidered": [
        {
          "option": "Python only",
          "pros": ["Single language", "Good for data science", "Simple deployment"],
          "cons": ["Performance limitations"]
        },
        {
          "option": "Python skills + Node server",
          "pros": ["Better MCP ecosystem support", "Performance"],
          "cons": ["Two languages to maintain"]
        }
      ],
      "decision": "Use Python for all components",
      "rationale": "Simplicity and consistency outweigh performance concerns for this use case",
      "consequences": ["Single language expertise needed", "Easier maintenance"],
      "relatedReqs": ["REQ-001", "REQ-005"],
      "relatedDecisions": []
    },
    {
      "id": "ADR-002",
      "title": "Subprocess dispatch for skills",
      "status": "accepted",
      "context": "MCP server needs to execute skill logic",
      "optionsConsidered": [
        {
          "option": "Import as modules",
          "pros": ["Faster", "Shared memory"],
          "cons": ["No isolation", "Memory leaks possible"]
        },
        {
          "option": "Subprocess execution",
          "pros": ["Complete isolation", "No memory leaks", "Crash isolation"],
          "cons": ["Slower", "IPC overhead"]
        }
      ],
      "decision": "Use subprocess execution",
      "rationale": "Isolation and stability more important than raw performance",
      "consequences": ["Each skill runs in isolated process", "Clean error handling"],
      "relatedReqs": ["REQ-005"],
      "relatedDecisions": ["ADR-001"]
    },
    {
      "id": "ADR-003",
      "title": "Pluggable data adapter architecture",
      "status": "accepted",
      "context": "Skills need market data but should remain pure",
      "optionsConsidered": [
        {
          "option": "Skills fetch directly",
          "pros": ["Simple", "Direct control"],
          "cons": ["Not testable", "Network in skills"]
        },
        {
          "option": "Separate data layer",
          "pros": ["Testable", "Skills stay pure", "Multiple sources"],
          "cons": ["Additional component"]
        }
      ],
      "decision": "Implement separate pluggable data adapter",
      "rationale": "Separation of concerns and testability are critical",
      "consequences": ["Clean architecture", "Easy to test", "Multiple data sources possible"],
      "relatedReqs": ["REQ-006"],
      "relatedDecisions": []
    },
    {
      "id": "ADR-004",
      "title": "Dual transport support",
      "status": "accepted",
      "context": "Need to support both desktop and hosted deployments",
      "optionsConsidered": [
        {
          "option": "stdio only",
          "pros": ["Simple", "Standard for MCP"],
          "cons": ["No remote access"]
        },
        {
          "option": "HTTP only",
          "pros": ["Remote access", "Standard REST"],
          "cons": ["Not native MCP"]
        },
        {
          "option": "Both stdio and HTTP",
          "pros": ["Maximum flexibility", "All use cases"],
          "cons": ["More complex"]
        }
      ],
      "decision": "Support both stdio and HTTP transports",
      "rationale": "Different deployment scenarios require different transports",
      "consequences": ["More complex server", "Broader compatibility"],
      "relatedReqs": ["REQ-007"],
      "relatedDecisions": []
    },
    {
      "id": "ADR-005",
      "title": "GitHub Actions for CI/CD",
      "status": "accepted",
      "context": "Need CI/CD pipeline for quality and releases",
      "optionsConsidered": [
        {
          "option": "GitHub Actions",
          "pros": ["Integrated with GitHub", "Free for public repos", "Good ecosystem"],
          "cons": ["Vendor lock-in"]
        },
        {
          "option": "Jenkins",
          "pros": ["Self-hosted", "Full control"],
          "cons": ["Maintenance overhead"]
        }
      ],
      "decision": "Use GitHub Actions",
      "rationale": "Integration and simplicity outweigh lock-in concerns",
      "consequences": ["Easy setup", "Good integration", "Some vendor dependency"],
      "relatedReqs": ["REQ-009", "REQ-010"],
      "relatedDecisions": []
    },
    {
      "id": "ADR-006",
      "title": "Multi-agent architecture",
      "status": "accepted",
      "context": "Complex analysis requires different perspectives",
      "optionsConsidered": [
        {
          "option": "Single monolithic analyzer",
          "pros": ["Simple", "One decision point"],
          "cons": ["Complex logic", "Hard to maintain"]
        },
        {
          "option": "Specialized agents",
          "pros": ["Separation of concerns", "Expert systems", "Maintainable"],
          "cons": ["Coordination needed"]
        }
      ],
      "decision": "Implement three specialized agents",
      "rationale": "Different analysis types benefit from specialization",
      "consequences": ["Clear responsibilities", "Better maintainability", "Need orchestration"],
      "relatedReqs": ["REQ-013"],
